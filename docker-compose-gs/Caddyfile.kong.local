{
	auto_https off
}

https://192.168.219.105:54322 {
	tls ./nginx/192.168.219.105+2.pem ./nginx/192.168.219.105+2-key.pem

	reverse_proxy http://127.0.0.1:54321 {
		# Inject the client IP observed at the host edge.
		header_up X-Forwarded-For {http.request.remote.host}
		header_up X-Real-IP {http.request.remote.host}
		header_up X-Forwarded-Proto https
		header_up Host {host}
	}
}
